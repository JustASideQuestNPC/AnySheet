<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AnySheet.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dialogs="using:AvaloniaDialogs.Views"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:cc="using:CustomControls"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="750"
        x:Class="AnySheet.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AnySheet"
        Focusable="True">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    
    <Window.Styles>
        <StyleInclude Source="/Assets/DialogStyles.axaml" />
        
        <Style Selector="Button.SquareIconButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Width" Value="{Binding $self.Bounds.Height}" />
        </Style>
        <Style Selector="Button.SquareIconButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Tertiary}" />
        </Style>
        <Style Selector="Button.SquareIconButton ToolTip">
            <Setter Property="Foreground" Value="{DynamicResource Primary}" />
            <Setter Property="Background" Value="{DynamicResource BackgroundPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BackgroundSecondary}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{DynamicResource Lato}" />
            <Setter Property="ShowDelay" Value="200" />
        </Style>
        <Style Selector="Button.SquareIconButton materialIcons|MaterialIcon">
            <Setter Property="Foreground" Value="{DynamicResource Primary}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="IconSize" Value="20" />
        </Style>
        <Style Selector="Button.SquareIconButton:disabled materialIcons|MaterialIcon">
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        
        <Style Selector="#TopButtonBar Panel.Spacer">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Width" Value="{Binding $self.Bounds.Height}" />
        </Style>
        
        <Style Selector="StackPanel.ModuleFolderList TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource LatoBold}" />
            <Setter Property="Foreground" Value="{DynamicResource Primary}" /> 
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="4" />
        </Style>
        
        <Style Selector="StackPanel.ModuleFileList Button">
            <Setter Property="Foreground" Value="{DynamicResource Primary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="FontFamily" Value="{DynamicResource Lato}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="StackPanel.ModuleFileList Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Tertiary}" />
        </Style>
        
        <Style Selector="cc|AutoFitTextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource Lato}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        
        <Style Selector="TextBlock.SaveIndicator">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource Primary}" />
            <Setter Property="FontFamily" Value="{DynamicResource Lato}" />
            <Setter Property="Opacity" Value="0" />
            <Style.Animations>
                <Animation Duration="0:0:1.0" FillMode="Forward">
                    <KeyFrame KeyTime="0.0">
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0.25">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                    <KeyFrame KeyTime="1.0">
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        
        <Style Selector="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource PtSerif}" />
            <Setter Property="Foreground" Value="{DynamicResource Primary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox:focus-within">
            <Setter Property="Foreground" Value="{DynamicResource Primary}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Primary}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="3" />
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource Primary}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Primary}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="TextBox:focus-within /template/ Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Styles>
    
    <Window.KeyBindings>
        <KeyBinding Command="{Binding CrashProgramCommand}" Gesture="Ctrl+Alt+OemOpenBrackets" />
        <KeyBinding Command="{Binding SaveSheetToCurrentPathCommand}" Gesture="Ctrl+S" />
        <KeyBinding Command="{Binding ResetCameraCommand}" Gesture="Ctrl+R" />
        <KeyBinding Command="{Binding ResetSheetPositionsCommand}" Gesture="Ctrl+Shift+R" />
        <KeyBinding Command="{Binding ChangeUiModeCommand}" CommandParameter="Gameplay" Gesture="Ctrl+G" />
        <KeyBinding Command="{Binding ChangeUiModeCommand}" CommandParameter="ModuleEdit" Gesture="Ctrl+B" />
    </Window.KeyBindings>
    
    <dialogs:ReactiveDialogHost Background="{DynamicResource BackgroundPrimary}" Padding="0"
                                CloseOnClickAway="False" Identifier="RootDialog">
        <DockPanel Background="{DynamicResource BackgroundPrimary}">
            <!-- top menu -->
            <StackPanel Name="TopButtonBar" DockPanel.Dock="Top" Orientation="Horizontal" Height="40"
                        Background="{DynamicResource BackgroundPrimary}" Margin="6 0">
                <!-- new/open/save/save as -->
                <Button Command="{Binding CreateNewSheetCommand}" Classes="SquareIconButton" ToolTip.Tip="New Sheet">
                    <materialIcons:MaterialIcon Kind="FilePlus" />
                </Button>
                <Button Command="{Binding OpenSheetFromFileCommand}" Classes="SquareIconButton"
                        ToolTip.Tip="Open Sheet">
                    <materialIcons:MaterialIcon Kind="FolderOpen" />
                </Button>
                <Button Command="{Binding SaveSheetToCurrentPathCommand}" Classes="SquareIconButton"
                        IsEnabled="{Binding SheetMenusEnabled}" ToolTip.Tip="Save">
                    <materialIcons:MaterialIcon Kind="ContentSave" />
                </Button>
                <Button Command="{Binding SaveSheetToNewPathCommand}" Classes="SquareIconButton"
                        IsEnabled="{Binding SheetMenusEnabled}" ToolTip.Tip="Save As">
                    <materialIcons:MaterialIcon Kind="ContentSavePlus" />
                </Button>
                
                <Panel Classes="Spacer" />
                
                <!-- mode selectors -->
                <Button Command="{Binding ChangeUiModeCommand}" CommandParameter="Gameplay" Classes="SquareIconButton"
                        IsEnabled="{Binding GameplayModeButtonEnabled}" ToolTip.Tip="Gameplay Mode">
                    <materialIcons:MaterialIcon Kind="Controller" Foreground="{Binding GameplayModeIconColor}"
                                                Opacity="{Binding ModeIconOpacity}" />
                </Button>
                <Button Command="{Binding ChangeUiModeCommand}" CommandParameter="ModuleEdit" Classes="SquareIconButton"
                        IsEnabled="{Binding ModuleEditModeButtonEnabled}" ToolTip.Tip="Sheet Builder Mode">
                    <materialIcons:MaterialIcon Kind="ToyBrickOutline" Foreground="{Binding ModuleEditModeIconColor}"
                                                Opacity="{Binding ModeIconOpacity}" />
                </Button>
                <Button Command="{Binding ChangeUiModeCommand}" CommandParameter="TriggerEdit"
                        Classes="SquareIconButton" IsEnabled="{Binding TriggerEditModeButtonEnabled}"
                        ToolTip.Tip="Triggers">
                    <materialIcons:MaterialIcon Kind="VectorPolyline"
                                                Foreground="{Binding TriggerEditModeIconColor}"
                                                Opacity="{Binding ModeIconOpacity}" />
                </Button>
                
                <Panel Classes="Spacer" />
                
                <!-- camera controls -->
                <Button Command="{Binding ResetCameraCommand}" Classes="SquareIconButton"
                        IsEnabled="{Binding SheetMenusEnabled}" ToolTip.Tip="Reset Camera">
                    <materialIcons:MaterialIcon Kind="Overscan" />
                </Button>
                <Button Command="{Binding ZoomInCommand}" Classes="SquareIconButton"
                        IsEnabled="{Binding ZoomButtonsEnabled}" ToolTip.Tip="Zoom In">
                    <materialIcons:MaterialIcon Kind="MagnifyAdd" />
                </Button>
                <Button Command="{Binding ZoomOutCommand}" Classes="SquareIconButton"
                        IsEnabled="{Binding ZoomButtonsEnabled}" ToolTip.Tip="Zoom Out">
                    <materialIcons:MaterialIcon Kind="MagnifyMinus" />
                </Button>
                
                <Panel Classes="Spacer" Width="20" />
                
                <ContentControl Content="{Binding SaveIndicator}" />
            </StackPanel>
            
            <!-- module sidebar -->
            <Border Margin="0" Padding="10" BorderBrush="{DynamicResource Primary}"
                    BorderThickness="0 2 2 0" IsVisible="{Binding ModuleSidebarEnabled}"
                    DockPanel.Dock="Left" Width="250">
                <Grid ColumnDefinitions="40, 40, *" RowDefinitions="40, *" RowSpacing="5">
                    <Button Command="{Binding ReloadModuleTreeCommand}"
                            Classes="SquareIconButton" ToolTip.Tip="Reload Module List">
                        <materialIcons:MaterialIcon Kind="Reload" />
                    </Button>
                    <Button Grid.Column="1" Grid.Row="0" Command="{Binding OpenModuleFolderCommand}"
                            Classes="SquareIconButton" ToolTip.Tip="Open Module Folder">
                        <materialIcons:MaterialIcon Kind="FolderOpen" />
                    </Button>
                    <TextBlock Grid.Column="2" Grid.Row="0" Foreground="{DynamicResource Primary}"
                               FontFamily="{DynamicResource LatoBold}" FontSize="20"
                               VerticalAlignment="Center">Modules</TextBlock>
                    <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3"
                            Background="{DynamicResource BackgroundSecondary}" CornerRadius="7">
                        
                        <!-- folder list -->
                        <ScrollViewer>
                            <StackPanel Classes="ModuleFolderList">
                                <ItemsControl ItemsSource="{Binding ModuleFolders}"><ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                    <Border Background="{DynamicResource BackgroundPrimary}"
                                            BorderBrush="{DynamicResource Primary}" CornerRadius="3"
                                            BorderThickness="2" Margin="3">
                                        <Grid RowDefinitions="30, Auto" ColumnDefinitions="*, 30">
                                            <TextBlock Text="{Binding FolderName}" />
                                            <Button Grid.Row="0" Grid.Column="1" Classes="SquareIconButton"
                                                    Command="{Binding ToggleFiles}">
                                                <materialIcons:MaterialIcon Kind="ChevronDown" />
                                            </Button>
                                            
                                            <!-- File List -->
                                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                    IsVisible="{Binding ShowFiles}"
                                                    BorderBrush="{DynamicResource Primary}"
                                                    BorderThickness="0 2 0 0">
                                                <StackPanel Classes="ModuleFileList">
                                                    <ItemsControl ItemsSource="{Binding FileButtons}">
                                                    <ItemsControl.ItemTemplate><DataTemplate>
                                                        <Button Command="{Binding AddModule}">
                                                            <cc:AutoFitTextBlock Text="{Binding DisplayName}" />
                                                        </Button>
                                                    </DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                                </ItemsControl.ItemTemplate></ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
            
            <!-- trigger sidebar -->
            <Border Margin="0" Padding="10" BorderBrush="{DynamicResource Primary}"
                    BorderThickness="0 2 2 0" IsVisible="{Binding TriggerSidebarEnabled}"
                    DockPanel.Dock="Left" Width="250">
                <Grid ColumnDefinitions="40, *" RowDefinitions="40, *, Auto" RowSpacing="5">
                    <Button Grid.Column="0" Grid.Row="0" Command="{Binding OpenModuleFolderCommand}"
                            Classes="SquareIconButton" ToolTip.Tip="New Trigger">
                        <materialIcons:MaterialIcon Kind="Plus" />
                    </Button>
                    <TextBlock Grid.Column="1" Grid.Row="0" Foreground="{DynamicResource Primary}"
                               FontFamily="{DynamicResource LatoBold}" FontSize="20"
                               VerticalAlignment="Center">Triggers</TextBlock>
                    
                    <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="{DynamicResource Primary}"
                            BorderThickness="2" Padding="2" CornerRadius="7">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding TriggerListEntries}" Margin="0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="3" BorderBrush="{DynamicResource Primary}"
                                                BorderThickness="2" CornerRadius="4"
                                                Background="{DynamicResource BackgroundPrimary}">
                                            <Grid Margin="0" ColumnDefinitions="*, 25, 25, 25"
                                                  RowDefinitions="Auto">
                                                <cc:AutoFitTextBlock Text="{Binding Text}"
                                                         Foreground="{DynamicResource Primary}" Padding="3 0"
                                                         FontSize="12" />
                                                <Button Grid.Column="1" Command="{Binding Activate}"
                                                        VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                        Classes="SquareIconButton">
                                                    <materialIcons:MaterialIcon Kind="PlayOutline"
                                                            Foreground="{DynamicResource Primary}"
                                                            VerticalAlignment="Stretch"
                                                            HorizontalAlignment="Stretch" />
                                                </Button>
                                                <Button Grid.Column="2" Command="{Binding SetEditing}"
                                                        VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                        Classes="SquareIconButton">
                                                    <materialIcons:MaterialIcon Kind="PencilOutline"
                                                            Foreground="{DynamicResource Primary}"
                                                            VerticalAlignment="Stretch"
                                                            HorizontalAlignment="Stretch" />
                                                </Button>
                                                <Button Grid.Column="3" Command="{Binding RemoveEntry}"
                                                        VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                                        Classes="SquareIconButton">
                                                    <materialIcons:MaterialIcon Kind="TrashCanOutline"
                                                            Foreground="{DynamicResource Primary}"
                                                            VerticalAlignment="Stretch"
                                                            HorizontalAlignment="Stretch" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    
                    <Border Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="0" Padding="3"
                            BorderBrush="Transparent">
                        <Grid Margin="0" Name="NewEntryContainerGrid" ColumnDefinitions="*, Auto, Auto"
                              RowDefinitions="25" ColumnSpacing="5">
                            <TextBox Name="NewEntryTextBox" Text="{Binding NewTriggerEntryName}"
                                     BorderThickness="0 0 0 3" BorderBrush="{DynamicResource Primary}"
                                     Foreground="{DynamicResource Primary}" Padding="3 0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            </TextBox>
                            <Button Grid.Column="1" Command="{Binding ClearTriggerEntryBoxCommand}"
                                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                    Classes="SquareIconButton" Margin="2">
                                <materialIcons:MaterialIcon Kind="Close" Foreground="{DynamicResource Primary}"
                                                            VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
                            </Button>
                            <Button Grid.Column="2" Command="{Binding CreateNewTriggerCommand}"
                                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                    Classes="SquareIconButton" Margin="2">
                                <materialIcons:MaterialIcon Kind="Plus" Foreground="{DynamicResource Primary}"
                                                            VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            
            <!-- character sheet -->
            <Panel Background="{DynamicResource BackgroundSecondary}">
                <ContentControl Content="{Binding LoadedSheet}" />
            </Panel>
        </DockPanel>
    </dialogs:ReactiveDialogHost>
</Window>
